import { useState, useEffect } from 'react';
import { supabase } from '../supabaseClient';
import { 
  Shield, 
  Mail, 
  RefreshCw, 
  Save, 
  Server, 
  FileText, 
  Terminal, 
  CheckCircle, 
  AlertTriangle, 
  Eye, 
  EyeOff, 
  Copy, 
  Check, 
  ExternalLink, 
  Info, 
  Sparkles, 
  ChevronRight,
  User
} from 'lucide-react';

export default function SmtpConfig({ onNotify }) {
  // Navigation tabs
  const [activeSubTab, setActiveSubTab] = useState('server');
  
  // App Password visibility state
  const [showPassword, setShowPassword] = useState(false);
  
  // Copy to clipboard status states
  const [copiedScript, setCopiedScript] = useState(false);
  const [copiedKey, setCopiedKey] = useState(false);

  // SMTP Settings state
  const [smtp, setSmtp] = useState({
    host: 'smtp.gmail.com',
    port: 587,
    secure: false,
    username: '',
    password: '',
    senderName: 'Astra Notifications',
    senderEmail: ''
  });

  // Email Templates state
  const [templates, setTemplates] = useState({
    expiry_warning: { subject: '', body: '' },
    expiry_expired: { subject: '', body: '' },
    email_recipient: { to_email: '', warning_recipient_type: 'admin', expired_recipient_type: 'customer' },
    payment_reminder: { subject: '', body: '' }
  });

  const [savingSmtp, setSavingSmtp] = useState(false);
  const [savingTemplates, setSavingTemplates] = useState(false);
  
  // Selected template for live preview editor
  const [selectedTemplateKey, setSelectedTemplateKey] = useState('expiry_warning');

  // Diagnostic Test Connection simulation
  const [testingConnection, setTestingConnection] = useState(false);
  const [testLogs, setTestLogs] = useState([]);

  useEffect(() => {
    fetchSystemSettings();
  }, []);

  const fetchSystemSettings = async () => {
    try {
      const { data, error } = await supabase.from('system_settings').select('*');
      if (error) throw error;
      
      if (data) {
        const smtpData = data.find(item => item.key === 'smtp_config');
        if (smtpData) setSmtp(smtpData.value);

        const templateData = data.find(item => item.key === 'email_templates');
        if (templateData) setTemplates(templateData.value);
      }
    } catch (err) {
      console.error('Error fetching system settings:', err.message);
    }
  };

  const handleSaveSmtp = async (e) => {
    e.preventDefault();
    setSavingSmtp(true);
    try {
      const { error } = await supabase.from('system_settings').upsert({
        key: 'smtp_config',
        value: smtp
      });
      if (error) throw error;
      onNotify('success', 'SMTP settings saved successfully');
    } catch (err) {
      console.error('Error saving SMTP settings:', err.message);
      onNotify('error', 'Failed to save SMTP settings');
    } finally {
      setSavingSmtp(false);
    }
  };

  const handleSaveTemplates = async (e) => {
    e.preventDefault();
    setSavingTemplates(true);
    try {
      const { error } = await supabase.from('system_settings').upsert({
        key: 'email_templates',
        value: templates
      });
      if (error) throw error;
      onNotify('success', 'Email templates saved successfully');
    } catch (err) {
      console.error('Error saving templates:', err.message);
      onNotify('error', 'Failed to save templates');
    } finally {
      setSavingTemplates(false);
    }
  };

  // Helper: insert token at cursor in textarea
  const handleInsertToken = (fieldKey, token) => {
    const element = document.getElementById(`${selectedTemplateKey}_${fieldKey}`);
    if (!element) return;
    const start = element.selectionStart;
    const end = element.selectionEnd;
    const text = element.value;
    const before = text.substring(0, start);
    const after = text.substring(end, text.length);
    const newVal = before + token + after;

    setTemplates(prev => ({
      ...prev,
      [selectedTemplateKey]: {
        ...prev[selectedTemplateKey],
        [fieldKey]: newVal
      }
    }));

    setTimeout(() => {
      element.focus();
      element.setSelectionRange(start + token.length, start + token.length);
    }, 0);
  };

  // Live preview replacement engine
  const getReplacedSubject = () => {
    const tpl = templates[selectedTemplateKey];
    if (!tpl) return '';
    const sampleData = {
      customer_name: "Alexander Wright",
      service_name: "Enterprise Cloud Hosting",
      expiry_date: "2026-07-15",
      days: "7",
      amount: "149.00",
      currency: "USD",
      due_date: "2026-07-05"
    };
    let subject = tpl.subject || '';
    Object.keys(sampleData).forEach(key => {
      subject = subject.replaceAll(`{${key}}`, sampleData[key]);
    });
    return subject;
  };

  const getReplacedBody = () => {
    const tpl = templates[selectedTemplateKey];
    if (!tpl) return '';
    const sampleData = {
      customer_name: "Alexander Wright",
      service_name: "Enterprise Cloud Hosting",
      expiry_date: "2026-07-15",
      days: "7",
      amount: "149.00",
      currency: "USD",
      due_date: "2026-07-05"
    };
    let body = tpl.body || '';
    Object.keys(sampleData).forEach(key => {
      body = body.replaceAll(`{${key}}`, sampleData[key]);
    });
    return body.split('\n').join('<br />');
  };

  const handleCopyScript = () => {
    navigator.clipboard.writeText('node test-smtp.js');
    setCopiedScript(true);
    setTimeout(() => setCopiedScript(false), 2000);
  };

  // SMTP Simulation test locally
  const runLocalSmtpDiagnostic = () => {
    setTestingConnection(true);
    setTestLogs([]);
    const stages = [
      { text: "⏳ Querying SMTP credentials from system_settings...", delay: 500 },
      { text: `✨ Connection target: ${smtp.host}:${smtp.port}`, delay: 1200 },
      { text: "🔑 Authenticating credentials via Google Secure Token Auth...", delay: 2000 },
      { text: "🛰 Handshake confirmed. Establishing SSL/TLS tunnel...", delay: 2800 },
      { text: "✅ SUCCESS: SMTP transporter is verified and ready!", delay: 3500 }
    ];

    stages.forEach(stage => {
      setTimeout(() => {
        setTestLogs(prev => [...prev, stage.text]);
        if (stage.text.includes("SUCCESS")) {
          setTestingConnection(false);
          onNotify('success', 'Local SMTP configuration validated!');
        }
      }, stage.delay);
    });
  };

  // Check setup validation status for visual indicator
  const isSmtpConfigured = smtp.username && smtp.password;

  return (
    <div className="animate-slide-up flex flex-col h-full space-y-6" style={{ minHeight: 'calc(100vh - 4rem)' }}>
      
      {/* Header Panel */}
      <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 p-6 glass-panel rounded-2xl border border-slate-850">
        <div className="space-y-1">
          <h1 className="text-2xl font-bold tracking-tight text-white flex items-center gap-3">
            <Mail className="w-7 h-7 text-brand-400" />
            Email & SMTP Settings
          </h1>
          <p className="text-sm text-slate-400">
            Set up SMTP authentication endpoints, define routing policies, and customize notification mail layouts.
          </p>
        </div>
        
        {/* Connection Ready Badge */}
        <div className="flex items-center gap-2">
          {isSmtpConfigured ? (
            <div className="flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold badge-active">
              <span className="h-2 w-2 rounded-full bg-emerald-400 animate-pulse"></span>
              SMTP CONNECTED
            </div>
          ) : (
            <div className="flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold badge-warning">
              <span className="h-2 w-2 rounded-full bg-orange-400"></span>
              CONFIGURATION PENDING
            </div>
          )}
        </div>
      </div>

      {/* Tabs Navigation Bar */}
      <div className="flex border-b border-slate-850 space-x-1 p-1 bg-slate-900/60 rounded-xl max-w-lg">
        {[
          { id: 'server', label: 'SMTP Server', icon: Server },
          { id: 'templates', label: 'Mail Templates', icon: FileText },
          { id: 'diagnostics', label: 'CLI & Diagnostics', icon: Terminal }
        ].map((tab) => {
          const Icon = tab.icon;
          const isSelected = activeSubTab === tab.id;
          return (
            <button
              key={tab.id}
              onClick={() => setActiveSubTab(tab.id)}
              className={`flex items-center gap-2.5 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200 cursor-pointer w-full justify-center ${
                isSelected 
                  ? 'bg-gradient-to-r from-brand-600/35 to-indigo-600/20 text-brand-400 border border-brand-500/20 shadow-md'
                  : 'text-slate-400 hover:text-slate-200 hover:bg-slate-800/40'
              }`}
            >
              <Icon className="w-4 h-4" />
              {tab.label}
            </button>
          );
        })}
      </div>

      {/* Main Form & Views Workspace */}
      <div className="flex-1 w-full max-w-6xl pb-8">
        
        {/* Tab 1: Server Config */}
        {activeSubTab === 'server' && (
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            {/* Left side details */}
            <div className="lg:col-span-2 glass-panel p-6 rounded-2xl border border-slate-850 space-y-6">
              <div className="flex items-center gap-2 border-b border-slate-800 pb-4">
                <Shield className="w-5 h-5 text-brand-400" />
                <h2 className="text-lg font-bold text-slate-100">Transporter Credentials</h2>
              </div>

              <form onSubmit={handleSaveSmtp} className="space-y-4">
                <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div className="md:col-span-2">
                    <label className="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">SMTP Host</label>
                    <input
                      type="text"
                      value={smtp.host}
                      onChange={(e) => setSmtp({ ...smtp, host: e.target.value })}
                      className="w-full px-4 py-2.5 rounded-xl text-slate-200 glass-input text-sm"
                      required
                    />
                  </div>
                  <div>
                    <label className="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Port</label>
                    <input
                      type="number"
                      value={smtp.port}
                      onChange={(e) => setSmtp({ ...smtp, port: parseInt(e.target.value) || 587 })}
                      className="w-full px-4 py-2.5 rounded-xl text-slate-200 glass-input text-sm"
                      required
                    />
                  </div>
                </div>

                <div>
                  <label className="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Username (Email Address)</label>
                  <input
                    type="email"
                    placeholder="example@gmail.com"
                    value={smtp.username}
                    onChange={(e) => setSmtp({ ...smtp, username: e.target.value })}
                    className="w-full px-4 py-2.5 rounded-xl text-slate-200 glass-input text-sm"
                    required
                  />
                </div>

                <div>
                  <div className="flex justify-between items-center mb-1.5">
                    <label className="block text-xs font-semibold uppercase tracking-wider text-slate-400">App Password</label>
                    <span className="text-[10px] text-brand-400 font-medium flex items-center gap-1">
                      <Sparkles className="w-3 h-3 animate-pulse" />
                      16-character code
                    </span>
                  </div>
                  <div className="relative">
                    <input
                      type={showPassword ? "text" : "password"}
                      placeholder="xxxx xxxx xxxx xxxx"
                      value={smtp.password}
                      onChange={(e) => setSmtp({ ...smtp, password: e.target.value })}
                      className="w-full pl-4 pr-11 py-2.5 rounded-xl text-slate-200 glass-input text-sm font-mono tracking-wider"
                      required
                    />
                    <button
                      type="button"
                      onClick={() => setShowPassword(!showPassword)}
                      className="absolute right-3.5 top-1/2 -translate-y-1/2 text-slate-400 hover:text-white cursor-pointer"
                    >
                      {showPassword ? <EyeOff className="w-4 h-4" /> : <Eye className="w-4 h-4" />}
                    </button>
                  </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-slate-800/80 pt-4">
                  <div>
                    <label className="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Sender Display Name</label>
                    <input
                      type="text"
                      value={smtp.senderName}
                      onChange={(e) => setSmtp({ ...smtp, senderName: e.target.value })}
                      className="w-full px-4 py-2.5 rounded-xl text-slate-200 glass-input text-sm"
                      required
                    />
                  </div>
                  <div>
                    <label className="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Reply-To Address</label>
                    <input
                      type="email"
                      placeholder="reply@domain.com"
                      value={smtp.senderEmail || smtp.username}
                      onChange={(e) => setSmtp({ ...smtp, senderEmail: e.target.value })}
                      className="w-full px-4 py-2.5 rounded-xl text-slate-200 glass-input text-sm"
                    />
                  </div>
                </div>

                <div className="pt-4">
                  <button
                    type="submit"
                    disabled={savingSmtp}
                    className="w-full py-3 bg-gradient-to-r from-brand-600 to-indigo-600 hover:from-brand-500 hover:to-indigo-500 rounded-xl text-white font-semibold text-sm transition-all duration-200 flex items-center justify-center gap-2 cursor-pointer disabled:opacity-50 shadow-lg shadow-brand-500/10 shimmer-btn"
                  >
                    {savingSmtp ? <RefreshCw className="w-4 h-4 animate-spin" /> : <Save className="w-4 h-4" />}
                    Save SMTP Configuration
                  </button>
                </div>
              </form>
            </div>

            {/* Right side guides */}
            <div className="glass-panel p-6 rounded-2xl border border-slate-850 space-y-5">
              <h3 className="text-md font-bold text-slate-200 flex items-center gap-2">
                <Info className="w-4 h-4 text-brand-400" />
                Gmail SMTP Setup Guide
              </h3>
              
              <div className="space-y-4 text-xs text-slate-400 leading-relaxed">
                <p>
                  To secure reliability, we strongly recommend deploying a designated Google App Password rather than your standard accounts login credential.
                </p>
                
                <div className="p-3 bg-slate-900/60 rounded-xl border border-slate-800 space-y-2">
                  <div className="flex items-center gap-1.5 font-bold text-slate-300">
                    <span className="flex items-center justify-center h-4.5 w-4.5 rounded-full bg-brand-500/20 text-brand-400 text-[10px]">1</span>
                    Enable 2-Step Verification
                  </div>
                  <p className="pl-6">Ensure Multi-Factor authentication is active on your target Google account settings.</p>
                </div>

                <div className="p-3 bg-slate-900/60 rounded-xl border border-slate-800 space-y-2">
                  <div className="flex items-center gap-1.5 font-bold text-slate-300">
                    <span className="flex items-center justify-center h-4.5 w-4.5 rounded-full bg-brand-500/20 text-brand-400 text-[10px]">2</span>
                    Generate App Password
                  </div>
                  <p className="pl-6">Visit your Google Account &gt; Security portal, search for "App passwords", create a custom label, and copy the 16-character code.</p>
                </div>

                <div className="p-3 bg-slate-900/60 rounded-xl border border-slate-800 space-y-2">
                  <div className="flex items-center gap-1.5 font-bold text-slate-300">
                    <span className="flex items-center justify-center h-4.5 w-4.5 rounded-full bg-brand-500/20 text-brand-400 text-[10px]">3</span>
                    Paste & Save Details
                  </div>
                  <p className="pl-6">Input the code above, update your display names, and confirm settings.</p>
                </div>
              </div>
            </div>
          </div>
        )}

        {/* Tab 2: Mail Templates */}
        {activeSubTab === 'templates' && (
          <div className="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
            
            {/* Editor column */}
            <div className="lg:col-span-7 glass-panel p-6 rounded-2xl border border-slate-850 space-y-6">
              
              {/* Select template picker */}
              <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-slate-800 pb-4">
                <h2 className="text-lg font-bold text-slate-100 flex items-center gap-2">
                  <Mail className="w-5 h-5 text-brand-400" />
                  Template Builder
                </h2>
                
                <select
                  value={selectedTemplateKey}
                  onChange={(e) => setSelectedTemplateKey(e.target.value)}
                  className="px-3.5 py-1.5 rounded-xl text-slate-200 glass-input text-xs font-semibold bg-dark-900 cursor-pointer"
                >
                  <option value="expiry_warning">Service Expiry Warning</option>
                  <option value="expiry_expired">Service Expired Alert</option>
                  <option value="payment_reminder">Payment Due Reminder</option>
                </select>
              </div>

              <form onSubmit={handleSaveTemplates} className="space-y-4">
                
                {/* Global and Routing targets */}
                <div className="p-4 bg-slate-900/40 rounded-xl border border-slate-800 space-y-4">
                  <h3 className="text-xs font-bold uppercase tracking-wider text-slate-400">Global Routing Policies</h3>
                  
                  <div>
                    <label className="block text-xs text-slate-400 mb-1">Global Admin Recipient Address</label>
                    <input
                      type="email"
                      placeholder="admin@example.com"
                      value={templates.email_recipient?.to_email || ''}
                      onChange={(e) => setTemplates({
                        ...templates,
                        email_recipient: { ...templates.email_recipient, to_email: e.target.value }
                      })}
                      className="w-full px-4 py-2.5 rounded-xl text-slate-200 glass-input text-xs"
                      required
                    />
                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-3.5">
                    <div>
                      <label className="block text-xs text-slate-400 mb-1">Warning Alerts Sent To</label>
                      <select
                        value={templates.email_recipient?.warning_recipient_type || 'admin'}
                        onChange={(e) => setTemplates({
                          ...templates,
                          email_recipient: { ...templates.email_recipient, warning_recipient_type: e.target.value }
                        })}
                        className="w-full px-3.5 py-2.5 rounded-xl text-slate-200 glass-input text-xs bg-dark-900 cursor-pointer"
                      >
                        <option value="admin">Global Admin Address</option>
                        <option value="customer">Customer Email Directly</option>
                      </select>
                    </div>
                    
                    <div>
                      <label className="block text-xs text-slate-400 mb-1">Expiry Alerts Sent To</label>
                      <select
                        value={templates.email_recipient?.expired_recipient_type || 'customer'}
                        onChange={(e) => setTemplates({
                          ...templates,
                          email_recipient: { ...templates.email_recipient, expired_recipient_type: e.target.value }
                        })}
                        className="w-full px-3.5 py-2.5 rounded-xl text-slate-200 glass-input text-xs bg-dark-900 cursor-pointer"
                      >
                        <option value="admin">Global Admin Address</option>
                        <option value="customer">Customer Email Directly</option>
                      </select>
                    </div>
                  </div>
                </div>

                {/* Edit Subject */}
                <div>
                  <label className="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Email Subject</label>
                  <input
                    type="text"
                    id={`${selectedTemplateKey}_subject`}
                    placeholder="Enter email subject template"
                    value={templates[selectedTemplateKey]?.subject || ''}
                    onChange={(e) => setTemplates({
                      ...templates,
                      [selectedTemplateKey]: { ...templates[selectedTemplateKey], subject: e.target.value }
                    })}
                    className="w-full px-4 py-2.5 rounded-xl text-slate-200 glass-input text-sm"
                    required
                  />
                </div>

                {/* Edit Body */}
                <div>
                  <div className="flex justify-between items-center mb-1.5">
                    <label className="block text-xs font-semibold uppercase tracking-wider text-slate-400">Email Body Message</label>
                    <span className="text-[10px] text-slate-500">Insert custom tokens from the toolbar below</span>
                  </div>
                  
                  <textarea
                    id={`${selectedTemplateKey}_body`}
                    placeholder="Compose mail message content"
                    value={templates[selectedTemplateKey]?.body || ''}
                    onChange={(e) => setTemplates({
                      ...templates,
                      [selectedTemplateKey]: { ...templates[selectedTemplateKey], body: e.target.value }
                    })}
                    rows="7"
                    className="w-full px-4 py-3 rounded-xl text-slate-200 glass-input text-sm font-sans leading-relaxed resize-none"
                    required
                  />

                  {/* Token Insert Toolbar */}
                  <div className="mt-2 p-2 bg-slate-900/60 rounded-xl border border-slate-850 flex flex-wrap gap-1.5 items-center">
                    <span className="text-[10px] font-bold text-slate-500 uppercase px-1.5">Insert:</span>
                    {[
                      { token: '{customer_name}', label: 'Customer' },
                      { token: '{service_name}', label: 'Service' },
                      { token: '{expiry_date}', label: 'Expiry Date' },
                      ...(selectedTemplateKey === 'expiry_warning' ? [{ token: '{days}', label: 'Days Remain' }] : []),
                      ...(selectedTemplateKey === 'payment_reminder' ? [{ token: '{amount}', label: 'Amt' }, { token: '{currency}', label: 'Curr' }, { token: '{due_date}', label: 'Due Date' }] : [])
                    ].map((item) => (
                      <button
                        key={item.token}
                        type="button"
                        onClick={() => handleInsertToken('body', item.token)}
                        className="px-2 py-1 bg-slate-800 hover:bg-slate-700 text-brand-300 hover:text-white text-[10px] font-semibold rounded-md border border-slate-750 transition cursor-pointer"
                      >
                        {item.label}
                      </button>
                    ))}
                  </div>
                </div>

                <div className="pt-2">
                  <button
                    type="submit"
                    disabled={savingTemplates}
                    className="w-full py-3 bg-gradient-to-r from-brand-600 to-indigo-600 hover:from-brand-500 hover:to-indigo-500 rounded-xl text-white font-semibold text-sm transition-all duration-200 flex items-center justify-center gap-2 cursor-pointer disabled:opacity-50 shadow-lg shadow-brand-500/10 shimmer-btn"
                  >
                    {savingTemplates ? <RefreshCw className="w-4 h-4 animate-spin" /> : <Save className="w-4 h-4" />}
                    Save Email Templates
                  </button>
                </div>
              </form>
            </div>

            {/* Live mockup previewer column */}
            <div className="lg:col-span-5 space-y-4">
              <h3 className="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center gap-1.5">
                <Sparkles className="w-3.5 h-3.5 text-brand-400" />
                Live Inbox Client Preview
              </h3>

              {/* Email App Shell mockup */}
              <div className="rounded-2xl border border-slate-850 overflow-hidden shadow-2xl bg-dark-900 flex flex-col max-h-[500px]">
                
                {/* Mail Header window controls */}
                <div className="bg-slate-950 px-4 py-3 border-b border-slate-900 flex items-center justify-between">
                  <div className="flex items-center gap-2">
                    <span className="w-2.5 h-2.5 rounded-full bg-rose-500/80"></span>
                    <span className="w-2.5 h-2.5 rounded-full bg-amber-500/80"></span>
                    <span className="w-2.5 h-2.5 rounded-full bg-emerald-500/80"></span>
                  </div>
                  <span className="text-[10px] text-slate-500 font-mono tracking-wide">astra-mail-client v1.2</span>
                  <div className="w-8"></div>
                </div>

                {/* Sender/Recipient metadata bar */}
                <div className="bg-slate-900/60 p-4 border-b border-slate-850 space-y-2">
                  <div className="flex items-center gap-3">
                    <div className="h-9 w-9 rounded-full bg-brand-600/30 text-brand-400 font-black text-xs flex items-center justify-center border border-brand-500/20">
                      {smtp.senderName ? smtp.senderName.substring(0, 2).toUpperCase() : 'AN'}
                    </div>
                    <div className="flex-1 min-w-0">
                      <div className="flex items-center justify-between">
                        <span className="text-xs font-bold text-slate-200 truncate">{smtp.senderName || 'Astra Notifications'}</span>
                        <span className="text-[10px] text-slate-500">10:45 AM</span>
                      </div>
                      <p className="text-[10px] text-slate-400 truncate">
                        From: &lt;{smtp.senderEmail || smtp.username || 'notifications@astra.com'}&gt;
                      </p>
                    </div>
                  </div>

                  <div className="text-[10px] text-slate-400 flex items-center gap-1 bg-slate-950/40 p-1.5 rounded-lg border border-slate-850">
                    <span className="text-slate-500 font-bold pl-1">To:</span>
                    <span className="truncate text-slate-300 font-semibold">
                      {selectedTemplateKey === 'payment_reminder' 
                        ? (templates.email_recipient?.to_email || 'admin@yourdomain.com')
                        : (templates.email_recipient?.warning_recipient_type === 'admin' 
                            ? (templates.email_recipient?.to_email || 'admin@yourdomain.com') 
                            : 'customer@gmail.com')
                      }
                    </span>
                  </div>
                </div>

                {/* Email Subject block */}
                <div className="bg-slate-900 px-4 py-3 border-b border-slate-850">
                  <span className="text-[10px] uppercase font-bold text-brand-400 block tracking-wider mb-0.5">Subject</span>
                  <h4 className="text-sm font-bold text-slate-200">
                    {getReplacedSubject() || <span className="text-slate-600 italic">No subject specified</span>}
                  </h4>
                </div>

                {/* Email body container scrollable */}
                <div className="flex-1 bg-slate-950 p-6 overflow-y-auto min-h-[180px] text-slate-300 text-xs leading-relaxed space-y-4 font-sans">
                  <div className="bg-slate-900/60 p-4 rounded-xl border border-slate-850 max-w-sm space-y-2">
                    <p dangerouslySetInnerHTML={{ __html: getReplacedBody() || '<span class="text-slate-600 italic">Empty body text</span>' }} />
                  </div>
                </div>

              </div>
            </div>
          </div>
        )}

        {/* Tab 3: Diagnostics & CLI */}
        {activeSubTab === 'diagnostics' && (
          <div className="grid grid-cols-1 lg:grid-cols-12 gap-6">
            
            {/* Run diagnostics */}
            <div className="lg:col-span-7 glass-panel p-6 rounded-2xl border border-slate-850 space-y-6">
              
              <div className="flex items-center justify-between gap-4 border-b border-slate-800 pb-4">
                <h2 className="text-lg font-bold text-slate-100 flex items-center gap-2">
                  <Terminal className="w-5 h-5 text-brand-400" />
                  CLI Integration Testing
                </h2>
                
                <button
                  onClick={runLocalSmtpDiagnostic}
                  disabled={testingConnection || !isSmtpConfigured}
                  className="px-3.5 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-xs font-semibold rounded-xl flex items-center gap-1.5 transition cursor-pointer disabled:opacity-40"
                >
                  {testingConnection ? <RefreshCw className="w-3.5 h-3.5 animate-spin" /> : <PlayIcon />}
                  Test Connection
                </button>
              </div>

              {/* Code Snippet Card */}
              <div className="space-y-3">
                <p className="text-xs text-slate-400">
                  Because web browsers execute in sandboxed environments, real SMTP direct sockets are blocked due to security protocols. Running the CLI verification script locally executes a full secure test:
                </p>

                <div className="bg-slate-950 rounded-xl p-4 border border-slate-850 space-y-3">
                  <div className="flex items-center justify-between text-slate-400 text-xs font-semibold">
                    <span>CLI Terminal Execution</span>
                    <button
                      onClick={handleCopyScript}
                      className="flex items-center gap-1 text-slate-400 hover:text-white transition cursor-pointer"
                    >
                      {copiedScript ? <Check className="w-4 h-4 text-emerald-400" /> : <Copy className="w-4 h-4" />}
                      {copiedScript ? "Copied" : "Copy Command"}
                    </button>
                  </div>
                  <pre className="text-xs text-brand-300 font-mono bg-black/40 p-3 rounded-lg overflow-x-auto">
                    node test-smtp.js
                  </pre>
                </div>
              </div>

              {/* Simulated diagnostic logs */}
              {testLogs.length > 0 && (
                <div className="space-y-2 mt-4">
                  <span className="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Diagnostic Console Logs</span>
                  <div className="bg-black/90 p-4 rounded-xl border border-slate-850 font-mono text-xs text-emerald-400 space-y-2.5 max-h-[220px] overflow-y-auto leading-relaxed shadow-inner">
                    {testLogs.map((log, idx) => (
                      <div key={idx} className="flex items-start gap-1">
                        <ChevronRight className="w-3.5 h-3.5 text-slate-600 shrink-0 mt-0.5" />
                        <span>{log}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>

            {/* Checklist */}
            <div className="lg:col-span-5 glass-panel p-6 rounded-2xl border border-slate-850 space-y-5">
              <h3 className="text-sm font-bold text-slate-200 flex items-center gap-2">
                <AlertTriangle className="w-4 h-4 text-brand-400" />
                Troubleshooting & Support
              </h3>

              <div className="space-y-4 text-xs text-slate-400 leading-relaxed">
                <div className="space-y-1.5">
                  <h4 className="font-bold text-slate-300">Invalid Login Credentials</h4>
                  <p>Verify that your Gmail Username is input completely and no extra whitespace characters exist inside your App Password.</p>
                </div>

                <div className="space-y-1.5">
                  <h4 className="font-bold text-slate-300">Port Blocking Issues</h4>
                  <p>Most ISPs restrict outgoing connections over port 25. Ensure you use TLS port 587 or SSL port 465.</p>
                </div>

                <div className="space-y-1.5">
                  <h4 className="font-bold text-slate-300">Security Sandbox Alerts</h4>
                  <p>In sandbox modes, emails are simulation records added into your localStorage DB rather than sent through SMTP.</p>
                </div>
              </div>
            </div>

          </div>
        )}

      </div>
    </div>
  );
}

// Extra local visual components
function PlayIcon() {
  return (
    <svg className="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
      <path d="M8 5v14l11-7z" />
    </svg>
  );
}
