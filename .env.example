# Project Astra Environment Variables Template
# Copy this file to .env and populate with your credentials.

VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Cloudinary: client-side unsigned uploads need ONLY cloud name + upload preset.
# NEVER add the Cloudinary API key/secret here with a VITE_ prefix - it would be
# bundled into the public browser build. Keep the API key/secret server-side only.
VITE_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
VITE_CLOUDINARY_UPLOAD_PRESET=YOUR_UPLOAD_PRESET
